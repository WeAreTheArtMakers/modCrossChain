NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_LIFI_API_KEY=
NEXT_PUBLIC_LIFI_INTEGRATOR=modCrossChain
NEXT_PUBLIC_DEFAULT_SLIPPAGE=0.005
# Optional LI.FI integrator fee as a decimal. Example: 0.0025 = 0.25%
NEXT_PUBLIC_LIFI_FEE=
# Disclosure-only minimum fee target for very small transfers. This does not add custody.
NEXT_PUBLIC_MIN_PLATFORM_FEE_NOTICE_USD=0.50

# Optional production RPC endpoints. The app falls back to public RPCs if omitted.
NEXT_PUBLIC_ETHEREUM_RPC_URL=
NEXT_PUBLIC_BNB_RPC_URL=
NEXT_PUBLIC_POLYGON_RPC_URL=
NEXT_PUBLIC_BASE_RPC_URL=
NEXT_PUBLIC_ARBITRUM_RPC_URL=
NEXT_PUBLIC_AVALANCHE_RPC_URL=
